# LLM Provider (supports OpenAI-compatible APIs)
# OpenRouter: https://openrouter.ai/api/v1
# NVIDIA NIM: https://integrate.api.nvidia.com/v1
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# Primary model for SQL generation (needs good reasoning)
LLM_MODEL=google/gemma-4-31b-it:free

# Smaller/cheaper model for response formatting
LLM_FORMAT_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Database
DATABASE_URL=postgresql://postgres:poc_password@localhost:5432/agent_db
