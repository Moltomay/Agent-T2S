# LLM Provider (supports OpenAI-compatible APIs)
# OpenRouter: https://openrouter.ai/api/v1
# NVIDIA NIM: https://integrate.api.nvidia.com/v1
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# Primary model for SQL generation (needs good reasoning)
LLM_MODEL=google/gemma-4-31b-it:free

# Smaller/cheaper model for response formatting
LLM_FORMAT_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Database — read-only user with SELECT on PMO tables + INSERT/DELETE on internal tables
# Create the user in PostgreSQL:
#   CREATE USER agent_reader WITH PASSWORD 'your_password';
#   GRANT CONNECT ON DATABASE your_db TO agent_reader;
#   GRANT USAGE ON SCHEMA public TO agent_reader;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO agent_reader;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO agent_reader;
#   GRANT SELECT, INSERT ON agent_memory TO agent_reader;
#   GRANT SELECT, INSERT, DELETE ON user_facts TO agent_reader;
#   ALTER TABLE agent_memory OWNER TO agent_reader;
#   ALTER TABLE user_facts OWNER TO agent_reader;
DATABASE_URL=postgresql://agent_reader:your_password@localhost:5433/platform_pmo
